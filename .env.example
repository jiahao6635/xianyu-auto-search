COZE_SUPABASE_URL=https://your-project-ref.supabase.co
COZE_SUPABASE_ANON_KEY=your-supabase-publishable-or-anon-key

COZE_PROJECT_ENV=DEV
PORT=5000
HOSTNAME=localhost

# Browser debugging
COZE_BROWSER_HEADLESS=false
COZE_BROWSER_SAVE_DEBUG=true

# Optional: use local installed browser
# COZE_BROWSER_CHANNEL=msedge
# COZE_BROWSER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Optional: reuse a persistent browser profile directory
# Note: if you point to your real Chrome/Edge profile, that browser should be closed first.
# COZE_BROWSER_USER_DATA_DIR=C:\Users\YourName\AppData\Local\Microsoft\Edge\User Data
